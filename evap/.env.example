# ==============================================================================
# EVAP – Enterprise Video Analytics Platform
# Environment Variables Template
# Copy to .env and fill in values before running.
# NEVER commit .env to version control.
# ==============================================================================

# ── Application ────────────────────────────────────────────────────────────────
APP_ENV=development                   # development | staging | production
APP_HOST=0.0.0.0
APP_PORT=8000
WORKERS=4                             # uvicorn worker processes
LOG_LEVEL=info                        # debug | info | warning | error | critical
DEBUG=false
TZ=UTC

# ── Security ───────────────────────────────────────────────────────────────────
# Generate with: openssl rand -hex 32
SECRET_KEY=your_64_char_hex_secret_key_here_change_in_production
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=your_fernet_encryption_key_here

# JWT
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=30
ALGORITHM=HS256

# ── PostgreSQL ─────────────────────────────────────────────────────────────────
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=evap
POSTGRES_PASSWORD=change_me_in_production
POSTGRES_DB=evap
# Async driver for FastAPI
DATABASE_URL=postgresql+asyncpg://evap:change_me_in_production@localhost:5432/evap
# Sync driver for Alembic migrations
DATABASE_URL_SYNC=postgresql://evap:change_me_in_production@localhost:5432/evap
# Connection pool
DB_POOL_SIZE=20
DB_MAX_OVERFLOW=40
DB_POOL_TIMEOUT=30
DB_ECHO=false

# ── Redis ──────────────────────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=change_me_redis_password
REDIS_DB=0
REDIS_URL=redis://:change_me_redis_password@localhost:6379/0
REDIS_MAX_CONNECTIONS=50
CACHE_TTL_DEFAULT=300
CACHE_TTL_EMPLOYEE=3600
CACHE_TTL_ATTENDANCE=60

# ── RabbitMQ ───────────────────────────────────────────────────────────────────
RABBITMQ_HOST=localhost
RABBITMQ_PORT=5672
RABBITMQ_USER=evap
RABBITMQ_PASSWORD=change_me_rabbitmq_password
RABBITMQ_VHOST=/
RABBITMQ_URL=amqp://evap:change_me_rabbitmq_password@localhost:5672/

# ── Celery ─────────────────────────────────────────────────────────────────────
CELERY_BROKER_URL=amqp://evap:change_me_rabbitmq_password@localhost:5672/
CELERY_RESULT_BACKEND=redis://:change_me_redis_password@localhost:6379/1
CELERY_WORKER_CONCURRENCY=4
CELERY_TASK_ALWAYS_EAGER=false          # Set to true for unit tests
CELERY_TASK_SERIALIZER=json
CELERY_RESULT_EXPIRES=3600

# ── API Configuration ──────────────────────────────────────────────────────────
API_V1_STR=/api/v1
PROJECT_NAME=EVAP – Enterprise Video Analytics Platform
CORS_ORIGINS=http://localhost:3000,http://localhost:8000
CORS_ALLOW_CREDENTIALS=true
DEFAULT_PAGE_SIZE=20
MAX_PAGE_SIZE=100

# ── Paths ──────────────────────────────────────────────────────────────────────
SNAPSHOTS_DIR=/app/snapshots
MEDIA_DIR=/app/media
TEMP_DIR=/tmp/evap

# ── Face Recognition (Phase 3 / Phase 4) ──────────────────────────────────────
MAX_FACE_DISTANCE=0.6                   # Maximum cosine distance for face match
FACE_DETECTION_CONFIDENCE=0.85          # Minimum detection confidence
FACE_RECOGNITION_TOLERANCE=0.5         # Distance threshold for identity match
FACE_ENCODING_MODEL=large              # small | large (dlib)
FACE_UPSAMPLING=1                       # How many times to upsample image
ENABLE_FACE_RECOGNITION=true

# ── GPU Acceleration ───────────────────────────────────────────────────────────
ENABLE_GPU_ACCELERATION=false           # Set to true when NVIDIA GPU available
CUDA_DEVICE=0                           # GPU device index

# ── Crowd Analytics ────────────────────────────────────────────────────────────
ENABLE_CROWD_ANALYTICS=true
CROWD_DENSITY_THRESHOLD=50              # People per 100m² before alert
CROWD_ALERT_COOLDOWN_SECONDS=300

# ── Vehicle Tracking ───────────────────────────────────────────────────────────
ENABLE_VEHICLE_TRACKING=false
PLATE_RECOGNITION_ENABLED=false
PLATE_RECOGNITION_CONFIDENCE=0.75

# ── Cross-Camera Re-ID ─────────────────────────────────────────────────────────
ENABLE_CROSS_CAMERA_REID=true
REID_SIMILARITY_THRESHOLD=0.7
REID_TRACKING_WINDOW_SECONDS=300

# ── Camera Stream Settings ─────────────────────────────────────────────────────
DEFAULT_STREAM_FPS=15                   # Target processing FPS
FRAME_BUFFER_SIZE=30                    # Frames to buffer per camera
CAMERA_RECONNECT_INTERVAL_SECONDS=10
CAMERA_HEALTH_CHECK_INTERVAL_SECONDS=30

# ── Attendance ─────────────────────────────────────────────────────────────────
ATTENDANCE_LATE_THRESHOLD_MINUTES=15
ATTENDANCE_ABSENT_THRESHOLD_HOURS=4
ATTENDANCE_TIMEZONE=UTC

# ── Canteen ────────────────────────────────────────────────────────────────────
CANTEEN_MEAL_WINDOW_MINUTES=30          # Time window for counting a meal
CANTEEN_OVERCROWDING_THRESHOLD=100

# ── Visitor Management ─────────────────────────────────────────────────────────
VISITOR_PRE_REGISTER_DAYS_AHEAD=14
VISITOR_OTP_EXPIRE_MINUTES=10
VISITOR_MAX_DURATION_HOURS=8

# ── Notifications ──────────────────────────────────────────────────────────────
SMTP_HOST=smtp.yourdomain.com
SMTP_PORT=587
SMTP_TLS=true
SMTP_USER=evap-notifications@yourdomain.com
SMTP_PASSWORD=change_me_smtp_password
SMTP_FROM=evap-notifications@yourdomain.com
SMTP_FROM_NAME=EVAP Security System

# Webhook for Slack/Teams/custom
ALERT_WEBHOOK_URL=
ALERT_WEBHOOK_ENABLED=false

# ── Object Storage (S3-compatible, for backups + snapshots) ───────────────────
S3_ENDPOINT_URL=                        # Leave blank for AWS S3; or set for MinIO etc.
S3_BUCKET=evap-backups
S3_ACCESS_KEY_ID=your_s3_access_key
S3_SECRET_ACCESS_KEY=your_s3_secret_key
S3_REGION=us-east-1
S3_PREFIX_BACKUPS=backups/postgres
S3_PREFIX_SNAPSHOTS=snapshots

# ── Monitoring ─────────────────────────────────────────────────────────────────
PROMETHEUS_PORT=8000
PROMETHEUS_METRICS_PATH=/metrics
ENABLE_METRICS=true

# Grafana admin (used by docker-compose grafana service)
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=change_me_grafana_password

# ── React Frontend (exposed to browser) ───────────────────────────────────────
REACT_APP_API_URL=http://localhost/api
REACT_APP_WS_URL=ws://localhost/ws
REACT_APP_VERSION=4.0.0
REACT_APP_SENTRY_DSN=                  # Optional: Sentry DSN for frontend error tracking

# ── Feature Flags ──────────────────────────────────────────────────────────────
FEATURE_FACE_RECOGNITION=true
FEATURE_CROWD_ANALYTICS=true
FEATURE_VEHICLE_TRACKING=false
FEATURE_CANTEEN_ANALYTICS=true
FEATURE_VISITOR_MANAGEMENT=true
FEATURE_CROSS_CAMERA_REID=true
FEATURE_REPORTS_PDF=true
FEATURE_AUDIT_LOG=true

# ── Rate Limiting ──────────────────────────────────────────────────────────────
RATE_LIMIT_DEFAULT=100/minute
RATE_LIMIT_AUTH=10/minute
RATE_LIMIT_UPLOADS=20/minute

# ── Sentry (backend error tracking) ───────────────────────────────────────────
SENTRY_DSN=                            # Optional: Sentry DSN
SENTRY_ENVIRONMENT=development
SENTRY_TRACES_SAMPLE_RATE=0.1

# ── Domain (used by nginx, cert-manager) ──────────────────────────────────────
EVAP_DOMAIN=evap.yourdomain.com
